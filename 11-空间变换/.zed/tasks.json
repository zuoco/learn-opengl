[
  {
    "label": "Configure Debug",
    "command": "cmake",
    "args": [
      "-B",
      "build",
      "-G",
      "Ninja",
      "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
      "-DCMAKE_CXX_COMPILER=clang++",
      "-DCMAKE_C_COMPILER=clang",
      "-DCMAKE_BUILD_TYPE=Debug",
    ],
    "cwd": "${ZED_WORKTREE_ROOT}",
  },
  {
    "label": "Build Debug",
    "command": "cmake",
    "args": ["--build", "build", "--config", "Debug", "--parallel"],
    "cwd": "${ZED_WORKTREE_ROOT}",
    "tags": ["build", "debug"],
  }
]